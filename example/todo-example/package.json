{
  "name": "todo-example",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "lint": "biome lint . && eslint 'cypress/**/*.js'",
    "lint:fix": "biome lint --write --unsafe . && eslint 'cypress/**/*.js' --fix",
    "fmt": "biome format .",
    "fmt:fix": "biome format --write .",
    "check": "biome check . && eslint 'cypress/**/*.js'",
    "check:fix": "biome check --write --unsafe . && eslint 'cypress/**/*.js' --fix",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run --browser chrome",
    "cypress:clean": "rm -rf cypress/pacts cypress/screenshots cypress/videos",
    "http-server": "http-server -p 3000 build/ &"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@pactflow/pact-cypress-adapter": "1.3.0",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "cypress": "15.18.1",
    "eslint": "9.39.5",
    "eslint-plugin-cypress": "6.4.3",
    "globals": "17.7.0",
    "http-server": "14.1.1",
    "tsx": "4.23.1",
    "vite": "8.1.5"
  }
}
