{
  "name": "@pactflow/pact-cypress-adapter",
  "version": "1.3.0",
  "description": "A cypress adapter for pact",
  "keywords": [
    "pact",
    "cypress",
    "contract testing",
    "ui"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/*.js",
    "dist/**/*.js",
    "dist/index.d.ts"
  ],
  "scripts": {
    "test": "vitest run",
    "build": "tsc",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write --unsafe .",
    "fmt": "biome format .",
    "fmt:fix": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write --unsafe .",
    "test:example": "cd example/todo-example && npm i && npm run check && npm run build && npm run http-server && npm run cypress:run",
    "release": "standard-version"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/lodash": "4.17.24",
    "@types/node": "24.13.3",
    "@vitest/ui": "4.1.10",
    "cypress": "15.18.1",
    "standard-version": "9.5.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "peerDependencies": {
    "cypress": "*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pactflow/cypress-pact-adapter.git"
  },
  "bugs": {
    "url": "https://github.com/pactflow/cypress-pact-adapter/issues"
  },
  "homepage": "https://github.com/pactflow/cypress-pact-adapter#readme"
}
